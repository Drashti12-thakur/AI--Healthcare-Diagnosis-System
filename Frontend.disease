<!DOCTYPE html>
<html>
<head>
    <title>AI Healthcare System</title>
</head>
<body>

<h2>Disease Prediction</h2>

<input type="text" id="symptoms" placeholder="Enter symptoms (comma separated)">
<button onclick="predict()">Predict</button>

<h3 id="result"></h3>

<script>
function predict() {
    let symptoms = document.getElementById("symptoms").value.split(",");

    fetch("http://127.0.0.1:5000/predict", {
        method: "POST",
        headers: {
            "Content-Type": "application/json"
        },
        body: JSON.stringify({ symptoms: symptoms })
    })
    .then(res => res.json())
    .then(data => {
        document.getElementById("result").innerHTML =
            "Disease: " + data.disease + "<br>" +
            "Medicines: " + data.medicines.join(", ") + "<br>" +
            "Confidence: " + data.confidence;
    });
}
</script>

</body>
</html>
